FROM ubuntu:24.04

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

RUN <<"EOF" bash -exu -o pipefail
export DEBIAN_FRONTEND=noninteractive
export TZ=America/Los_Angeles

apt-get update
apt-get install -y --no-install-recommends \
    qemu-system \
    qemu-user \
    qemu-user-static \
    binfmt-support

apt-get install -y --no-install-recommends software-properties-common
add-apt-repository -y ppa:apptainer/ppa
apt-get update
CODENAME=$(. /etc/os-release && echo "$VERSION_CODENAME")
apt-get install -y --no-install-recommends apptainer=1.5.0-2-1~${CODENAME}
ln -sf /usr/bin/apptainer /usr/bin/singularity

apt-get clean
rm -rf /var/lib/apt/lists/*
EOF

# Verify installation during build
RUN qemu-system-x86_64 --version && \
    qemu-aarch64 --version
RUN apt-get update && apt-get install -y sudo && sudo update-binfmts --enable qemu-aarch64 && sudo update-binfmts --enable qemu-x86_64

CMD ["/bin/bash"]
